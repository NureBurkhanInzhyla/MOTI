<Window x:Class="Lab1MOTI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Main Window" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="LPR">
                <StackPanel Margin="10">
                    <DataGrid x:Name="dgLRP" AutoGenerateColumns="True" Height="200" SelectionMode="Single"/>
                    <DockPanel Margin="0,10" LastChildFill="False">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button Content="Add LPR" Click="AddLpr_Click" Width="50" Margin="2"/>
                            <Button Content="Edit" Click="EditLpr_Click" Margin="2" Width="50"/>
                            <Button Content="Delete" Click="DeleteLpr_Click" Margin="2" Width="50" Background="Tomato"/>
                        </StackPanel>
                        <Button Content="Do Evaluation" 
                            Click="DoEvaluation_Click" 
                            DockPanel.Dock="Right" 
                            Margin="2" 
                            Background="LightBlue" 
                            FontWeight="Bold" 
                            Padding="10,2"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Alternatives and Criterions">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14*"/>
                        <ColumnDefinition Width="9*"/>
                        <ColumnDefinition Width="374*"/>
                        <ColumnDefinition Width="397*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="10,10,10,10" Grid.ColumnSpan="3">
                        <Label Content="Alternatives:"/>
                        <DataGrid x:Name="dgAlt" AutoGenerateColumns="True" Height="150" SelectionMode="Single"/>
                        <TextBox x:Name="txtAltName" Margin="0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10">
                            <Button Content="Add" Click="AddAlternative_Click" Margin="2"/>
                            <Button Content="Edit" Click="EditAlternative_Click" Margin="2"/>
                            <Button Content="Delete" Click="DeleteAlternative_Click" Margin="2" Background="Tomato"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="10,10,10,10">
                        <Label Content="Criterions:"/>
                        <DataGrid x:Name="dgCrit" AutoGenerateColumns="True" Height="150" SelectionMode="Single"/>
                        <TextBox x:Name="txtCritName" Margin="0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10">
                            <Button Content="Add" Click="AddCriterion_Click" Margin="2"/>
                            <Button Content="Edit" Click="EditCriterion_Click" Margin="2"/>
                            <Button Content="Delete" Click="DeleteCriterion_Click" Margin="2" Background="Tomato"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Vector">
                <StackPanel Margin="10">
                    <DataGrid x:Name="dgVectors" AutoGenerateColumns="False" Height="200" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Alternative" Binding="{Binding Alternative.AlternativeName}"/>
                            <DataGridTextColumn Header="Criterion" Binding="{Binding Criterion.CriterionName}"/>
                            <DataGridTextColumn Header="Mark" Binding="{Binding Mark}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button Content="Add Mark" Click="AddVector_Click" Margin="2"/>
                        <Button Content="Edit" Click="EditVector_Click" Margin="2"/>
                        <Button Content="Delete" Click="DeleteVector_Click" Margin="2" Background="Tomato"/>
                    
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="Results">
                <StackPanel Margin="10">
                    <DataGrid x:Name="dgResults" AutoGenerateColumns="False" Height="200" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="LPR Name" Binding="{Binding LPR.LPRName}" Width="*"/>
                            <DataGridTextColumn Header="LPR Range" Binding="{Binding LPRRange}" Width="100"/>

                            <DataGridTextColumn Header="Alternative" Binding="{Binding Alternative.AlternativeName}" Width="*"/>

                            <DataGridTextColumn Header="Alternative Range" Binding="{Binding AlternativeRange}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <DockPanel Margin="0,10" LastChildFill="False">
                        <StackPanel Orientation="Horizontal" Width="400" DockPanel.Dock="Left">
                            <Button Content="Add Result" Click="AddResult_Click" Margin="2"/>
                            <Button Content="Edit" Click="EditResult_Click" Margin="2"/>
                            <Button Content="Delete" Click="DeleteResult_Click" Margin="2" Background="Tomato"/>
                        </StackPanel>
                        <Button Content="View Voting Profile" 
                             Click="viewVoting_Click" 
                             DockPanel.Dock="Right" 
                             Margin="2" 
                             Background="LightSeaGreen" 
                             FontWeight="Bold" 
                             Foreground="White"
                             Padding="8,5"/>
                    </DockPanel>
                    <GroupBox Header="Матриця суміжності" Margin="5">
                        <DataGrid x:Name="dgMatrix" 
                          AutoGenerateColumns="True" 
                          IsReadOnly="True" 
                          HeadersVisibility="All" 
                          FontSize="14"
                          AlternatingRowBackground="GhostWhite"/>
                    </GroupBox>
                </StackPanel>
                
            </TabItem>
        </TabControl>
    </Grid>
</Window>