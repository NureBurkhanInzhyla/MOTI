<Window x:Class="Lab1MOTI.EditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab1MOTI"
        mc:Ignorable="d"
        Title="EditDialog" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <Label x:Name="lblFirst" Content="Name:"/>
            <TextBox x:Name="txtFirst" Margin="0,5"/>

            <Label x:Name="lblSecond" Content="Range (optional):" Visibility="Collapsed"/>
            <TextBox x:Name="txtSecond" Margin="0,5" Visibility="Collapsed"/>

            <Label x:Name="lblCombo1" Content="Choose element:" Visibility="Collapsed"/>
            <ComboBox x:Name="cbFirst" Margin="0,5" Visibility="Collapsed"/>

            <Label x:Name="lblCombo2" Content="Choose criterion:" Visibility="Collapsed"/>
            <ComboBox x:Name="cbSecond" Margin="0,5" Visibility="Collapsed"/>

            <Button Content="Save" Click="Save_Click" Margin="0,20" Height="30"/>
        </StackPanel>
    </Grid>
</Window>
